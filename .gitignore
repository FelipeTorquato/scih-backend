# ==========================================
# Build Tools & Outputs (Maven / Gradle)
# ==========================================
target/
build/
out/
bin/
.gradle/
buildNumber.properties
release.properties
pom.xml.releaseBackup
pom.xml.next
pom.xml.tag
pom.xml.versionsBackup

# Keep Maven/Gradle wrapper executable jars if you use them
!/.mvn/wrapper/maven-wrapper.jar
!/gradle/wrapper/gradle-wrapper.jar

# ==========================================
# Spring Boot Specifics & Configurations
# ==========================================
.sts4-cache/
.springBeans/
*.log
*.log.[0-9]
logs/

# Sensitive application configurations (always use env variables for secrets)
.env
.env.local
application-*.properties
application-*.yml
!application-dev.properties
!application-dev.yml

# ==========================================
# IDE Specifics (IntelliJ, Eclipse, VS Code)
# ==========================================
